          "name": "Barbell Bench Press",
          "muscle_group": "Chest",
          "sets": 3,
          "target_reps": "6-8",
          "starting_weight_kg": 30,
          "starting_reps": 6,
          "rest_seconds": 120,
          "reference_url": "https://exrx.net/WeightExercises/PectoralSternal/BBBenchPress"
